{
	"compilerOptions": {
		"target": "ES2022",
		"types": ["node"],
		"module": "ES2022",
		"moduleResolution": "Bundler",
		"rootDir": "src",
		"outDir": "dist",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"emitDeclarationOnly": false,
		"strict": true,
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts"]
}
